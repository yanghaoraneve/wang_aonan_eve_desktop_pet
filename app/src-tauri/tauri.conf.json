{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "桌宠小楠",
  "version": "0.1.0",
  "identifier": "com.eve.desktop-pet",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "pet",
        "title": "桌宠小楠",
        "width": 360,
        "height": 500,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "url": "index.html"
      },
      {
        "label": "chat",
        "title": "与小楠聊天",
        "width": 720,
        "height": 560,
        "visible": false,
        "center": true,
        "url": "chat.html"
      },
      {
        "label": "settings",
        "title": "小楠设置",
        "width": 520,
        "height": 680,
        "visible": false,
        "center": true,
        "url": "settings.html"
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "shortDescription": "桌宠小楠 Q版桌宠",
    "longDescription": "桌宠小楠 Q版桌宠，支持 Agent 聊天与换装",
    "category": "Utility",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
